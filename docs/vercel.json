{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "flutter build web --release --dart-define=API_BASE_URL=$API_BASE_URL --dart-define=WS_BASE_URL=$WS_BASE_URL",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}